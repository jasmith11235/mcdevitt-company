# ─── Database ──────────────────────────────────────────────────────────────────
# Supabase: https://supabase.com → Project → Settings → Database
# Use the pooled connection string (recommended for serverless / Vercel)
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# ─── Auth.js ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"

# ─── Microsoft Entra ID (Azure AD) ─────────────────────────────────────────────
# Register an app at https://portal.azure.com → App registrations
# Redirect URI: https://yourdomain.com/api/auth/callback/microsoft-entra-id
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
# Leave as "common" to allow any Microsoft account,
# or set to your tenant ID to restrict to your organisation only
MICROSOFT_TENANT_ID="common"

# ─── Google OAuth (optional) ───────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Superadmin bootstrap ──────────────────────────────────────────────────────
# Your email address. Run `npm run db:seed` once after first deploy.
SUPERADMIN_EMAIL="james@mcdevitt.com"

# ─── Contact form delivery ─────────────────────────────────────────────────────
# Every submission is saved to the database regardless of the settings below.
# These only control the optional notifications.
#
# Resend (email). Key from https://resend.com → API Keys. Without it, email is
# skipped (lead still saved). Verify a domain/subdomain for inbox deliverability.
RESEND_API_KEY=""
# Where inquiries are emailed. Falls back to content/pages/contact.json `email`.
# Set this to route to James without changing the public address on the site.
CONTACT_TO_EMAIL=""
# From address. Verified Resend domain, else keep the shared onboarding sender.
# e.g. "McDevitt Website <no-reply@mcdevitt.com>"
CONTACT_FROM_EMAIL=""
# Interim Google Sheet mirror (before Salesforce). Apps Script Web App URL that
# appends each submission as a row. Optional — leave blank to skip.
SHEET_WEBHOOK_URL=""
